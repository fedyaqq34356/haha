@echo off
setlocal enabledelayedexpansion

chcp 65001 >nul

set "filename=output"
set "text=Прошу обратить внимание на то, что в школе работают лица без соответствующего образования и квалификации для преподавания"

set count=15

:: Создаём первый файл
echo %text% > "%filename%.txt"

echo Начинаем создание файлов с разными датами...

for /L %%i in (1,1,%count%) do (
    set "newfile=%filename%%%i.txt"
    
    copy /y "%filename%.txt" "!newfile!" >nul 2>&1
    
    :: Изменяем дату создания и модификации (разные для каждого файла)
    powershell -NoProfile -Command ^
    "$file=Get-Item '!newfile!'; $randDays=-(Get-Random -Minimum 30 -Maximum 800); $randHours=Get-Random -Minimum 0 -Maximum 24; $randMin=Get-Random -Minimum 0 -Maximum 60; $date=(Get-Date).AddDays($randDays).AddHours($randHours).AddMinutes($randMin); $file.CreationTime=$date; $file.LastWriteTime=$date; $file.LastAccessTime=$date" >nul 2>&1
    
    echo Создан: !newfile!
)

echo.
echo Готово! Создано %count% файлов с максимально разными датами создания.
pause
endlocal